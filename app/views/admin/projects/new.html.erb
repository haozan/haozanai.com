<% content_for :title, "New Project" %>

<div class="container-md">
  <div class="flex items-center space-x-4">
    <%= link_to admin_projects_path, class: "btn-ghost text-sm py-1 px-3" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Projects
    <% end %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mt-4 mb-8">Create New Project</h1>

  <!-- Form -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <%= form_with model: [:admin, @project], local: true, class: "space-y-6" do |form| %>
        <%= render 'shared/form_error_message', model: @project %>

        <!-- Title -->
        <div class="mb-4">
          <%= form.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Title<% if field_required?(@project, :title) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.text_field :title, {
            placeholder: "Enter title...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@project, :title) ? { required: true } : {}) %>
          <% if @project.errors[:title].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @project.errors[:title].first %></p>
          <% end %>
        </div>

        <!-- Description -->
        <div class="mb-4">
          <%= form.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Description<% if field_required?(@project, :description) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.text_area :description, {
            rows: 5,
            placeholder: "Enter description...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@project, :description) ? { required: true } : {}) %>
          <% if @project.errors[:description].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @project.errors[:description].first %></p>
          <% end %>
        </div>

        <!-- Url -->
        <div class="mb-4">
          <%= form.label :url, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Url<% if field_required?(@project, :url) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.text_field :url, {
            placeholder: "Enter url...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@project, :url) ? { required: true } : {}) %>
          <% if @project.errors[:url].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @project.errors[:url].first %></p>
          <% end %>
        </div>

        <!-- External Cover URL (Priority: Highest) -->
        <div class="mb-4">
          <%= form.label :external_cover_url, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            External Cover URL <span class="text-blue-500 text-xs">(Recommended: 七牛云/CDN)</span>
          <% end %>
          <%= form.text_field :external_cover_url, {
            placeholder: "https://cdn.example.com/cover.jpg",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          } %>
          <p class="text-sm text-blue-500 dark:text-blue-400 mt-1 font-medium">⚡ Fastest loading - paste your CDN/七牛云 image URL here for optimal performance</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Recommended: 1200x628px, &lt;200KB, WebP/JPG format</p>
        </div>

        <!-- Cover Image -->
        <div class="mb-4">
          <%= form.label :cover_image, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Upload Cover Image <span class="text-gray-500 text-xs">(or use URL above/og:image)</span>
          <% end %>
          <% if @project.cover_image.attached? %>
            <div class="mb-3">
              <%= image_tag @project.cover_image, class: "w-64 h-auto border border-gray-300 dark:border-gray-600 rounded-lg" %>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Current uploaded image (auto-optimized to 1200x628px)</p>
            </div>
          <% end %>
          <%= form.file_field :cover_image, {
            accept: "image/*",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          } %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Priority: External URL > Uploaded Image > og:image from URL</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">📌 Best practice: Upload 1200x628px images. System auto-optimizes larger images.</p>
        </div>

        <!-- Status -->
        <div class="mb-4">
          <%= form.label :status, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Status<% if field_required?(@project, :status) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.text_field :status, {
            placeholder: "Enter status...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@project, :status) ? { required: true } : {}) %>
          <% if @project.errors[:status].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @project.errors[:status].first %></p>
          <% end %>
        </div>

        <!-- Position -->
        <div class="mb-4">
          <%= form.label :position, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Position<% if field_required?(@project, :position) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.number_field :position, {
            placeholder: "Enter position...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@project, :position) ? { required: true } : {}) %>
          <% if @project.errors[:position].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @project.errors[:position].first %></p>
          <% end %>
        </div>

        <!-- Form Actions -->
        <div class="flex justify-end space-x-3">
          <%= link_to admin_projects_path, class: "btn-ghost" do %>
            Cancel
          <% end %>
          <%= form.submit "Create Project", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>