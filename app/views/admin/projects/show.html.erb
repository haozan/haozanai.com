<% content_for :title, @project.respond_to?(:name) ? @project.name : "Project" %>

<div class="container-lg">
  <div class="mb-6">
    <div class="flex items-center space-x-4">
      <%= link_to admin_projects_path, class: "btn-ghost text-sm py-1 px-3" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Projects
      <% end %>
    </div>

    <div class="mt-4 flex items-center justify-between">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @project.respond_to?(:name) ? @project.name : "Project ##{@project.id}" %></h1>

      <div class="flex items-center space-x-3">
        <%= link_to edit_admin_project_path(@project.id), class: "btn-primary" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          Edit
        <% end %>

        <%= link_to admin_project_path(@project.id),
            method: :delete,
            data: { confirm: "Are you sure you want to delete this project?" },
            class: "btn-danger" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Delete
        <% end %>
      </div>
    </div>
  </div>

  <!-- Project Content -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <div class="space-y-6">
        <!-- Cover Image Priority Status -->
        <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4">
          <h3 class="text-sm font-semibold text-blue-900 dark:text-blue-100 mb-3">📸 Cover Image Priority Status</h3>
          <div class="space-y-2 text-sm">
            <div class="flex items-start gap-2">
              <span class="<%= @project.external_cover_url.present? ? 'text-green-600 dark:text-green-400 font-bold' : 'text-gray-400' %>">①</span>
              <div class="flex-1">
                <span class="font-medium">External CDN URL:</span>
                <% if @project.external_cover_url.present? %>
                  <span class="text-green-600 dark:text-green-400 font-bold ml-2">✓ ACTIVE</span>
                  <div class="mt-1 text-xs text-gray-600 dark:text-gray-400 break-all"><%= @project.external_cover_url %></div>
                <% else %>
                  <span class="text-gray-400 ml-2">Not set</span>
                <% end %>
              </div>
            </div>
            <div class="flex items-start gap-2">
              <span class="<%= @project.cover_image.attached? && @project.external_cover_url.blank? ? 'text-green-600 dark:text-green-400 font-bold' : 'text-gray-400' %>">②</span>
              <div class="flex-1">
                <span class="font-medium">Uploaded Image:</span>
                <% if @project.cover_image.attached? %>
                  <span class="<%= @project.external_cover_url.present? ? 'text-yellow-600 dark:text-yellow-400' : 'text-green-600 dark:text-green-400 font-bold' %> ml-2">
                    <%= @project.external_cover_url.present? ? '✓ Available (not used)' : '✓ ACTIVE' %>
                  </span>
                  <div class="mt-1 text-xs text-gray-600 dark:text-gray-400">(Auto-optimized to 1200x628px, quality 85%)</div>
                <% else %>
                  <span class="text-gray-400 ml-2">Not uploaded</span>
                <% end %>
              </div>
            </div>
            <div class="flex items-start gap-2">
              <span class="<%= @project.cover_image_url.present? && @project.external_cover_url.blank? && !@project.cover_image.attached? ? 'text-green-600 dark:text-green-400 font-bold' : 'text-gray-400' %>">③</span>
              <div class="flex-1">
                <span class="font-medium">OG:Image from URL:</span>
                <% if @project.cover_image_url.present? %>
                  <span class="<%= (@project.external_cover_url.present? || @project.cover_image.attached?) ? 'text-yellow-600 dark:text-yellow-400' : 'text-green-600 dark:text-green-400 font-bold' %> ml-2">
                    <%= (@project.external_cover_url.present? || @project.cover_image.attached?) ? '✓ Available (not used)' : '✓ ACTIVE' %>
                  </span>
                  <div class="mt-1 text-xs text-gray-600 dark:text-gray-400 break-all"><%= @project.cover_image_url %></div>
                <% else %>
                  <span class="text-gray-400 ml-2">Not fetched</span>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Current Display Cover -->
        <% if @project.display_cover_url.present? %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Current Display Cover</label>
            <img src="<%= @project.display_cover_url %>" alt="<%= @project.title %>" class="w-full max-w-2xl rounded-lg border border-gray-200 dark:border-gray-700" loading="lazy">
          </div>
        <% end %>

        <!-- Title -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Title</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @project.title %></div>
        </div>

        <!-- Description -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Description</label>
          <div class="prose prose-gray dark:prose-invert max-w-none">
            <%= simple_format(@project.description) %>
          </div>
        </div>

        <!-- Url -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Url</label>
          <div class="flex items-center gap-3">
            <div class="text-lg font-medium text-gray-900 dark:text-gray-100 flex-1"><%= @project.url %></div>
            <%= link_to refresh_cover_admin_project_path(@project), 
                method: :post,
                class: "btn-secondary text-sm py-2 px-4",
                data: { confirm: "Refresh cover image from og:image?" } do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
              Refresh Cover
            <% end %>
          </div>
        </div>

        <!-- Status -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Status</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @project.status %></div>
        </div>

        <!-- Position -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Position</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @project.position %></div>
        </div>

        <!-- Metadata -->
        <div class="pt-6 border-t border-gray-200 dark:border-gray-600">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">ID</label>
              <div class="text-sm text-gray-900 dark:text-gray-100 font-mono"><%= @project.id %></div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Created</label>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                <%= @project.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                <span class="text-gray-400">(<%= time_ago_in_words(@project.created_at) %> ago)</span>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Last Updated</label>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                <%= @project.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
                <span class="text-gray-400">(<%= time_ago_in_words(@project.updated_at) %> ago)</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
