<% content_for :title, "New Article" %>

<div class="container-md">
  <div class="flex items-center space-x-4">
    <%= link_to admin_articles_path, class: "btn-ghost text-sm py-1 px-3" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Articles
    <% end %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mt-4 mb-8">Create New Article</h1>

  <!-- Form -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <%= form_with model: [:admin, @article], local: true, class: "space-y-6" do |form| %>
        <%= render 'shared/form_error_message', model: @article %>

        <!-- Title -->
        <div class="mb-4">
          <%= form.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Title<% if field_required?(@article, :title) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.text_field :title, {
            placeholder: "Enter title...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@article, :title) ? { required: true } : {}) %>
          <% if @article.errors[:title].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @article.errors[:title].first %></p>
          <% end %>
        </div>

        <!-- Content -->
        <div class="mb-4">
          <%= form.label :content, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Content<% if field_required?(@article, :content) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.text_area :content, {
            rows: 5,
            placeholder: "Enter content...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@article, :content) ? { required: true } : {}) %>
          <% if @article.errors[:content].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @article.errors[:content].first %></p>
          <% end %>
        </div>

        <!-- Excerpt -->
        <div class="mb-4">
          <%= form.label :excerpt, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Excerpt<% if field_required?(@article, :excerpt) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.text_area :excerpt, {
            rows: 5,
            placeholder: "Enter excerpt...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@article, :excerpt) ? { required: true } : {}) %>
          <% if @article.errors[:excerpt].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @article.errors[:excerpt].first %></p>
          <% end %>
        </div>

        <!-- Published at -->
        <div class="mb-4">
          <%= form.label :published_at, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Published at<% if field_required?(@article, :published_at) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.datetime_local_field :published_at, {
            placeholder: "Enter published at...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@article, :published_at) ? { required: true } : {}) %>
          <% if @article.errors[:published_at].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @article.errors[:published_at].first %></p>
          <% end %>
        </div>

        <!-- Status -->
        <div class="mb-4">
          <%= form.label :status, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" do %>
            Status<% if field_required?(@article, :status) %> <span class="text-red-500">*</span><% end %>
          <% end %>
          <%= form.text_field :status, {
            placeholder: "Enter status...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-gray-50"
          }.merge(field_required?(@article, :status) ? { required: true } : {}) %>
          <% if @article.errors[:status].any? %>
            <p class="text-sm text-red-500 mt-1"><%= @article.errors[:status].first %></p>
          <% end %>
        </div>

        <!-- Form Actions -->
        <div class="flex justify-end space-x-3">
          <%= link_to admin_articles_path, class: "btn-ghost" do %>
            Cancel
          <% end %>
          <%= form.submit "Create Article", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>